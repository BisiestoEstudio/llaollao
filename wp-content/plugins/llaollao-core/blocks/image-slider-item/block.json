{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "llaollao/image-slider-item",
	"version": "1.0.0",
	"title": "Slider · imagen",
	"category": "media",
	"icon": "format-image",
	"description": "Una imagen del slider, con su proporción propia (o la original del archivo) y su punto focal.",
	"textdomain": "llaollao-core",
	"parent": [ "llaollao/image-slider" ],
	"attributes": {
		"id":         { "type": "integer" },
		"url":        { "type": "string",  "default": "" },
		"alt":        { "type": "string",  "default": "" },
		"width":      { "type": "integer", "default": 0 },
		"height":     { "type": "integer", "default": 0 },
		"ratio":      { "type": "string",  "default": "" },
		"focalPoint": { "type": "object",  "default": { "x": 0.5, "y": 0.5 } }
	},
	"supports": {
		"html":     false,
		"reusable": false
	},
	"editorScript": "file:./build/index.js",
	"render":       "file:./render.php"
}
