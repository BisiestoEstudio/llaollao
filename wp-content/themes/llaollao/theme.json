				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--bree)",
					"fontSize": "clamp(40px, 5.83vw + 5px, 75px)",
					"lineHeight": "1.15",
					"fontWeight": "700"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--bree)",
					"fontSize": "clamp(32px, 4.67vw + 4px, 60px)",
